# Hiking Map API Configuration
# 
# NEVER commit these files to git!
# Copy this to .env and fill in your actual values
# See: https://github.com/ivaneser/hiking-map

# ========================================
# DEVELOPMENT / LOCAL USE
# ========================================
# For development, you can use demo mode which stores keys in localStorage without encryption
# OR set a password for encrypted storage
DEMO_MODE=true

# OpenRouteService API Key (development/demo - not recommended for production)
# Get a free key: https://openrouteservice.org/dev/#/signup
OR_API_KEY_DEV=demo_key_replace_in_production

# ========================================
# PRODUCTION / GitHub Pages Deployment
# ========================================
# For production, generate proper API keys from the providers
# DO NOT commit this file! Copy to .env locally only.

# OpenRouteService Production API Key
# Get key at: https://openrouteservice.org/dev/#/signup
OR_API_KEY_PRODUCTION=your_production_key_here

# ========================================
# GitHub Actions Secrets (NOT in this file)
# ========================================
# These are stored in GitHub repo settings, not in .env
# 
# Repository Settings → Secrets and variables → Actions → New repository secret
# Add these secrets:
#   OR_API_KEY
#   OVERPASS_API_KEY (if needed)
